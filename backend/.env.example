PORT=5000
NODE_ENV=development

# Secret JWT (96 caractères hexadécimaux — régénérez-le en production : openssl rand -hex 48)
JWT_SECRET=remplacez_par_un_secret_de_64_caracteres_minimum_openssl_rand_hex_48

# Base de données Turso (https://turso.tech — gratuit, données persistantes en production).
# Si vide, un fichier SQLite local est utilisé (backend/database/marketbf.db) — parfait en développement.
# URL :   turso db show marketbf --url
# Token : turso db tokens create marketbf
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# URL du frontend (utilisée dans les liens des emails et le CORS)
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173

# Connexion Google — créez un OAuth Client ID sur https://console.cloud.google.com/apis/credentials
# (type "Application Web", origine JavaScript autorisée : http://localhost:5173)
GOOGLE_CLIENT_ID=

# Envoi d'emails (SMTP). Si vide, les emails sont simulés dans la console du serveur.
# Exemple Gmail : SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=votre@gmail.com,
# SMTP_PASS=mot-de-passe-application (https://myaccount.google.com/apppasswords)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Market BF" <no-reply@marketbf.com>
